# SiteAgent — ignore runtime + secrets + vendored deps
node_modules/
.env
*.local
.DS_Store

# Per-tenant runtime state (instances, uploads, secrets) — never commit
tenant-users/

# Local dev working dir + auto-generated master key (secret) at repo root — never commit
.tmp/

# Instatic vendored install artifacts (the source is cloned; deps/build are local)
instatic/vendor/node_modules/
instatic/vendor/dist/
instatic/vendor/.tmp/

# Operator console build
operator/ui/dist/
operator/ui/.astro/

# Control-plane local state (never commit — contains enc.key master key)
operator/control-plane/.state/
Insatic/operator/control-plane/.state/
*.log

# OpenDesign vendored app — install artifacts, local daemon state, secrets
OpenDesign/node_modules/
OpenDesign/**/node_modules/
OpenDesign/node_modules.old_delete/
OpenDesign/**/dist/
OpenDesign/apps/web/.next/
OpenDesign/apps/daemon/dist/
OpenDesign/**/*.sqlite
OpenDesign/**/*.sqlite3
OpenDesign/**/config.toml
OpenDesign/.tmp/
OpenDesign/.od/
OpenDesign/pnpm-install*.log
OpenDesign/build.log
OpenDesign/rebuild*.log
OpenDesign/docker-pull.log
