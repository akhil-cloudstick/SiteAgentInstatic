# This project lives on an SMB network share (\\ZAISERVER\dev_projects) where
# pnpm's default symlink/junction virtual store does not work. A flat hoisted
# layout uses real directories and is SMB-safe. Lifecycle scripts run under
# Git bash (UNC cwd + POSIX ||/&& support).
node-linker=hoisted
script-shell=C:\Program Files\Git\usr\bin\bash.exe
